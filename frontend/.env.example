# URL da API - em produção, deixe vazio ou use a URL do próprio frontend
# O proxy interno vai redirecionar para o BACKEND_URL
# Desenvolvimento: http://localhost:8000
# Produção: (deixe vazio - usa o proxy)
NEXT_PUBLIC_API_URL=

# URL do backend (usado pelo proxy server-side, NÃO exposto no cliente)
# Desenvolvimento: http://localhost:8000
# Produção: http://seu-backend.railway.app ou IP:porta
BACKEND_URL=http://localhost:8000
